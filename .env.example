# --- MySQL (optional) ---
# Set DB_ENABLED=true to activate. Fill in the rest to connect.
DB_ENABLED=false
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
# REQUIRED for managed DBs like Aiven (SSL required by server).
DB_SSL_MODE=REQUIRED
DB_CONNECT_TIMEOUT=10

# --- Market regime (策略根据大盘环境切换阈值) ---
# 启用后,按大盘指数 lookback 日涨幅切换三态:
#   涨幅 >= +APP_REGIME_RISK_ON_THRESHOLD%   → RISK_ON  (放宽关键阈值,放大扫描)
#   涨幅 <= APP_REGIME_RISK_OFF_THRESHOLD%  → RISK_OFF (默认停止推送,可改为仅收紧)
#   其他                                    → NEUTRAL  (默认阈值,行为与原版一致)
# 设置 APP_REGIME_ENABLED=false 可整体关闭,回到未引入 regime 时的行为。
APP_REGIME_ENABLED=true
APP_REGIME_INDEX_SYMBOL=sh000300
APP_REGIME_LOOKBACK_DAYS=20
APP_REGIME_RISK_ON_THRESHOLD=5.0
APP_REGIME_RISK_OFF_THRESHOLD=-3.0

# 阈值乘数 (1.0 = 不改动;默认启用时实盘行为零变化)
APP_REGIME_RISK_ON_CHANGE_MULT=0.85
APP_REGIME_RISK_ON_AMOUNT_MULT=0.85
APP_REGIME_RISK_OFF_CHANGE_MULT=1.6
APP_REGIME_RISK_OFF_AMOUNT_MULT=1.6

# RISK_OFF 时是否直接停止推送信号
APP_REGIME_RISK_OFF_PAUSE=true
